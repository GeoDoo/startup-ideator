generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  timezone      String       @default("UTC")

  teams                 TeamMember[]
  sentInvitations       Invitation[]     @relation("InvitedBy")
  accounts              Account[]
  sessions              Session[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference?
  deletionRequest       DeletionRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  stage       String?
  domain      String?

  members            TeamMember[]
  invitations        Invitation[]
  assessments        Assessment[]
  reports            Report[]
  pulseSchedule      PulseSchedule?
  milestones         Milestone[]
  ventureInputs      VentureInput[]
  ventureCandidates  VentureCandidate[]
  ventureSelection   VentureSelection?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("partner")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  assessments    Assessment[]
  ventureInputs  VentureInput[]
  ventureRatings VentureRating[]

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  teamId    String
  token     String   @unique @default(cuid())
  status    String   @default("pending")
  invitedBy String

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("InvitedBy", fields: [invitedBy], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email, teamId])
}

model Assessment {
  id           String @id @default(cuid())
  teamId       String
  memberId     String
  type         String @default("initial") // "initial" | "pulse"
  status       String @default("in_progress") // "in_progress" | "completed"

  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  responses AssessmentResponse[]

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teamId, memberId])
}

model AssessmentResponse {
  id           String @id @default(cuid())
  assessmentId String
  sectionKey   String
  questionKey  String
  answer       Json

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentId, sectionKey, questionKey])
}

model Report {
  id       String @id @default(cuid())
  teamId   String
  type     String @default("compatibility") // "compatibility" | "venture"
  version  Int    @default(1)
  status   String @default("generating") // "generating" | "ready" | "failed"

  content  Json?
  scores   Json?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([teamId, type])
}

model VentureInput {
  id       String @id @default(cuid())
  teamId   String
  memberId String
  status   String @default("in_progress") // "in_progress" | "completed"

  responses Json @default("{}")

  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([teamId, memberId])
}

model VentureCandidate {
  id     String @id @default(cuid())
  teamId String
  round  Int    @default(1)

  problem         String
  solution        String
  customer        String
  businessModel   String
  marketOpportunity String
  competitiveLandscape String
  teamFitScore    Int
  feasibility     String
  first90Days     String
  revenueTimeline String
  riskLevel       String
  industry        String

  ratings VentureRating[]
  team    Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([teamId, round])
}

model VentureRating {
  id          String @id @default(cuid())
  candidateId String
  memberId    String
  excitement  Int
  confidence  Int
  fit         Int
  commitment  Int
  rank        Int?
  notes       String?

  candidate VentureCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  member    TeamMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, memberId])
}

model VentureSelection {
  id          String @id @default(cuid())
  teamId      String @unique
  candidateId String
  status      String @default("selected") // "selected" | "pivoted"
  deepAnalysis Json?
  actionPlan   Json?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PulseSchedule {
  id        String @id @default(cuid())
  teamId    String @unique
  frequency String @default("monthly") // "weekly" | "biweekly" | "monthly" | "quarterly"
  nextDue   DateTime?
  active    Boolean @default(true)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Milestone {
  id          String @id @default(cuid())
  teamId      String
  title       String
  description String?
  recordedBy  String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([teamId])
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String
  title   String
  body    String
  link    String?
  read    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  emailInvitations   Boolean @default(true)
  emailAssessments   Boolean @default(true)
  emailReports       Boolean @default(true)
  emailPulseSurveys  Boolean @default(true)
  emailDigest        Boolean @default(false)
  inAppAll           Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model DeletionRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("pending") // "pending" | "processing" | "completed" | "cancelled"
  reason    String?

  scheduledAt DateTime
  processedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
